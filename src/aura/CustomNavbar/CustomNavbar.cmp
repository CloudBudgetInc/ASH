      <div class="{!!v.loggedIn ? 'navbar__actions' : 'navbar__actions navbar__actions--auth'}">
        <aura:if isTrue="{!v.loggedIn}">
          <a
            class="{! join(' ',
              'navbar__btn sm navbar__btn-ashrc nav-link'
            )}"
            href="{!v.homeLink}"
          >
          <img
            class="navbar__btn-icon"
            src="{!$ContentAsset.ashrc_logo_blue}"
            alt="avatar-icon"
          />
          <span
            class="navbar__btn-label"
          >
            {!v.homeLinkMobileLabel}
          </span>
        </a>
        <a
          class="{! join(' ',
            'navbar__btn sm navbar__btn-dashboard nav-link'
          )}"
          href="{!v.memberLink}"
        >
          <img
            class="navbar__btn-icon"
            src="{!$ContentAsset.dashboard}"
            alt="avatar-icon"
          />
          <span
            class="navbar__btn-label"
          >
            {!v.memberLinkMobileLabel}
          </span>
        </a>
        </aura:if>
        <!-- <button
          class="{! join(' ',
            'navbar__btn navbar__btn-search'
          )}"
          onclick="{!c.openSearch}"
          id="search-btn"
        >
          <img
            class="navbar__btn-icon"
            src="{!$ContentAsset.Search_Icon}"
            alt="avatar-icon"
            id="search-btn"
          />
          <span
            class="navbar__btn-label"
            id="search-btn"
          >
            Search
          </span>
        </button> -->
        <aura:if isTrue="{! !v.loggedIn}">
          <button
            class="{! join(' ',
              'navbar__btn navbar__btn-login'
            )}"
            onclick="{!c.openLogin}"
            id="login-btn"
          >
            <img
              class="navbar__btn-icon"
              src="{!$ContentAsset.Profile_Icon}"
              alt="avatar-icon"
              id="login-btn"
            />
            <span
              class="navbar__btn-label"
              id="login-btn"
            >
              Sign In
            </span>
          </button>
        </aura:if>
        <button
          class="{! join(' ',
            'navbar__btn navbar__btn-menu'
          )}"
          onclick="{!c.openMenu}"
          id="menu-btn"
        >
          <aura:if isTrue="{!v.menuOpen}">
            <img
              class="navbar__btn-icon"
              src="{!$ContentAsset.Hamburger_Close_Icon}"
              alt="avatar-icon"
              id="menu-btn"
            />
            <aura:set attribute="else">
              <img
                class="navbar__btn-icon"
                src="{!$ContentAsset.Hamburger_Menu_Icon}"
                alt="avatar-icon"
                id="menu-btn"
              />
            </aura:set>
          </aura:if>
          <span
            class="navbar__btn-label"
            id="menu-btn"
          >
            <aura:if isTrue="{!v.menuOpen}">
              Close
              <aura:set attribute="else">
                Menu
              </aura:set>
            </aura:if>
          </span>
        </button>
      </div>
    </nav>
    
    <!-- Search Component -->
    <div
      class="{! join(' ',
        'navbar__search',
        v.searchOpen ? 'open' : '',
        v.loggedInNav ? 'navbar__search--auth' : ''
      )}"
    >
      <c:CustomSearch cancel="{!c.handleSearchClose}" />
    </div>

    <!-- Login Component -->
    <aura:if isTrue="{! !v.loggedIn}">
      <div
        class="{! join(' ',
          'navbar__login',
          v.loginOpen ? 'open' : ''
        )}"
      >
        <c:CustomLogin startUrl="{!v.startUrl}" cancel="{!c.handleLoginClose}" />
      </div>
    </aura:if>
  </div>
</aura:component>